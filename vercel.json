{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/:path((?!ai-assistance|_next|api|css|js|images|fonts|icons|static).*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ],
  "buildCommand": "npx tailwindcss -i ./css/input.css -o ./css/tailwind.css --minify || true",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/ai-assistance",
      "destination": "https://yaniv-legal-ai.vercel.app/ai-assistance"
    },
    {
      "source": "/ai-assistance/:path*",
      "destination": "https://yaniv-legal-ai.vercel.app/ai-assistance/:path*"
    }
  ],
